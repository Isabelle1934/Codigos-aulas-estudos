#Programa para classificar se um número é positivo, negativo ou zero.

#O usuário usa o input e converte para float/decimal
try:
    num = float(input("Enter a number: "))
    if num > 0: #Se for maior que zero, "The number is positive."
        print("The number is positive.")
    elif num < 0: #Se for menor que zero, "The number is negative."
        print("The number is negative.")
    else: #Se não, "The number is zero."
        print("The number is zero.")
except ValueError:
  print("Invalid input. Please enter a numeric value.")
