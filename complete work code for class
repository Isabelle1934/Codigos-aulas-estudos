#Mensagem de boas-vindas mais uma mensagem dizendo as opções do menu.
print('Bem-vinda à Pizzaria da Isabelle Silva!')
print('----------- CARDÁPIO -----------')
print('Tamanho P - Pizza Salgada (PS) = R$30 | Pizza Doce (PD) = R$34')
print('Tamanho M - Pizza Salgada (PS) = R$45 | Pizza Doce (PD) = R$48')
print('Tamanho G - Pizza Salgada (PS) = R$60 | Pizza Doce (PD) = R$66')
print('--------------------------------')

#Aqui é uma variável que vai guardar um valor, nesse caso vai guardar o total dos pedidos feito pelo cliente.
total = 0

#O 'While' é usado como uma estrutura de repetição, nesse caso, enquanto for verdadeiro ele vai rodar as condições abaixo. Entrada pedindo para o cliente o sabor da pizza. O 'upper' funciona para deixar a resposta posta(input) pelo usuário em maiúsculo(.upper). '!=' é um comparador, ou seja, se os valores forem iguais ele vai trazer a mensagem do print abaixo.
while True:
    sabor = input("Digite o sabor (PS/PD): ").upper()
    if sabor != "PS" and sabor != "PD":
        print("Sabor inválido. Tente novamente")
        continue

#Aqui coloca o tamanho da pizza com letra maiúscula(.upper)
    tamanho = input("Digite o tamanho (P/M/G): ").upper()

#Aqui vai acontecer a mesma coisa que aconteceu quando foi pedido o sabor da pizza.
    if tamanho != "P" and tamanho != "M" and tamanho != "G":
        print("Tamanho inválido. Tente novamente")
        continue 
    if sabor == "PS":
        if tamanho == "P":
            preco = 30
        elif tamanho == "M":
            preco = 45
        elif tamanho == "G":
            preco = 60
    elif sabor == "PD":
        if tamanho == "P":
            preco = 34
        elif tamanho == "M":
            preco = 48
        elif tamanho == "G":
            preco = 66

    #Aqui é a soma dos valores que foram guardados na nossa variável + o preço do produto adicionado.
    total += preco
    print(f"Pedido adicionado: R$ {preco:.2f}")
    continuar = input("Deseja pedir mais alguma coisa? (S/N): ").upper()

    if continuar == "N":
        break  #Encerra o loop e termina o pedido.

#Resultado final do pedido do usuário.
print(f'Valor total do pedido: R$ {total:.2f}')

